# DashScope API Key (https://dashscope.aliyun.com/)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# System prompt — define your doll's personality
SYSTEM_PROMPT=你是一个可爱的 AI 玩偶，说话简洁温柔有趣，每次回答不超过50字。

# LLM model (auto-selects qwen-vl-max when image attached)
# Options: qwen-max, qwen-plus, qwen-turbo, qwen-vl-max
LLM_MODEL=qwen-max

# TTS voice
# Options: longxiaochun, longyuezi, longhua, longshuo, longshu, longxiaoxia, longxiaobai
TTS_VOICE=longxiaochun

# Sample rate of DashScope TTS output (adjust if audio sounds wrong)
# Try 22050 or 16000 if 24000 sounds off
TTS_SAMPLE_RATE=24000

# Server port (Railway/Render set this automatically)
PORT=3000
